# Supabase - Transaction Pooler (porta 6543) - para queries normais
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# Supabase - Direct Connection (porta 5432) - para migrations (prisma migrate deploy)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].supabase.com:5432/postgres"

JWT_SECRET="your_jwt_secret_here"
PORT=3333

# URL do frontend deployado no Render (para CORS)
FRONTEND_URL="https://your-frontend.onrender.com"

# Keep-alive interno entre serviços Render (opcional)
# Observação: se os dois serviços forem suspensos ao mesmo tempo, o timer também para.
# Para maior confiabilidade, prefira manter o workflow do GitHub Actions ativo.
KEEP_ALIVE_ENABLED=false
KEEP_ALIVE_INTERVAL_MS=600000
KEEP_ALIVE_TARGETS="https://eduia-backend.onrender.com"
