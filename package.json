{
  "name": "biblioteca-emprestimos-api",
  "version": "0.1.0",
  "description": "Backend do Sistema de Gerenciamento de Empréstimos de Livros",
  "main": "dist/shared/infra/http/server.js",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/shared/infra/http/server.ts",
    "debug": "node --inspect-brk ./node_modules/tsx/dist/cli.mjs watch src/shared/infra/http/server.ts",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "start": "node dist/shared/infra/http/server.js",
    "test": "jest --passWithNoTests --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node dist/shared/infra/database/prisma/seed.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "prisma": "^7.4.2",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
